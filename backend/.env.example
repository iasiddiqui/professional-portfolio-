NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# PostgreSQL
DATABASE_URL=postgresql://portfolio:changeme@localhost:5432/portfolio_db

# JWT (min 32 characters)
JWT_SECRET=dev-jwt-secret-replace-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-replace-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# External services (replace with real keys)
GEMINI_API_KEY=your-gemini-api-key
RESEND_API_KEY=your-resend-api-key
GITHUB_TOKEN=your-github-personal-access-token

# CORS
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# File uploads
PUBLIC_URL=http://localhost:4000
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Optional — seed admin user on db:seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
