NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# PostgreSQL
# Local: DATABASE_URL=postgresql://portfolio:changeme@localhost:5432/portfolio_db
# Neon: DATABASE_URL = pooled connection (-pooler in hostname), DIRECT_URL = direct connection
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://portfolio:changeme@localhost:5432/portfolio_db

# JWT (min 32 characters)
JWT_SECRET=dev-jwt-secret-replace-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-replace-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# External services (replace with real keys)
GEMINI_API_KEY=your-gemini-api-key
# gemini-2.0-flash has no free-tier quota; use gemini-2.5-flash or enable billing
GEMINI_MODEL=gemini-2.5-flash
RESEND_API_KEY=your-resend-api-key

# CORS
CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# File uploads
PUBLIC_URL=http://localhost:4000
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Optional — seed admin user on db:seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Login/register: 6 attempts per minute (~1 every 10 seconds)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=6
AUTH_REFRESH_RATE_LIMIT_MAX=60
