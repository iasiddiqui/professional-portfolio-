NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Portfolio
NEXT_PUBLIC_SITE_DESCRIPTION=Professional portfolio showcasing projects, case studies, blog, and services.
# Comma-separated image hostnames for next/image (defaults to API hostname)
# NEXT_PUBLIC_IMAGE_HOSTS=localhost,your-cdn.example.com
# Cloudinary cloud name for next/image remote patterns
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Set to true only in development to expose /register
# NEXT_PUBLIC_ALLOW_REGISTRATION=true
# NEXT_PUBLIC_TWITTER_HANDLE=@yourhandle
# NEXT_PUBLIC_OG_IMAGE=/og-default.svg
