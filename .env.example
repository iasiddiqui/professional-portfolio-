# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=portfolio_db
DATABASE_URL=postgresql://portfolio:changeme@localhost:5432/portfolio_db

# ─── Backend ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Optional integrations (server starts without them; endpoints fail gracefully)
GEMINI_API_KEY=your-gemini-api-key
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Portfolio <onboarding@resend.dev>
CONTACT_NOTIFICATION_EMAIL=you@example.com
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_USERNAME=your-github-username

# Security & limits
ALLOW_PUBLIC_REGISTRATION=true
CORS_ORIGIN=http://localhost:3000
GITHUB_CACHE_TTL_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=10
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5
GITHUB_RATE_LIMIT_WINDOW_MS=900000
GITHUB_RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=6
AUTH_REFRESH_RATE_LIMIT_MAX=60
GEMINI_MODEL=gemini-2.0-flash
PUBLIC_URL=http://localhost:4000
AUTH_COOKIE_PATH=/

# Seed admin (optional)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me-in-production

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Portfolio
NEXT_PUBLIC_SITE_DESCRIPTION=Professional portfolio showcasing projects, case studies, blog, and services.
NEXT_PUBLIC_ALLOW_REGISTRATION=true
